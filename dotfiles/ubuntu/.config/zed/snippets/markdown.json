{
  "Code bloc": {
    "prefix": "code",
    "body": ["```${1:code}", "${2:}", "```", ""],
    "description": "Bloc code"
  },
  "Image bloc": {
    "prefix": "img",
    "body": ["![${1:alt}](${2:})", ""],
    "description": "Bloc image"
  },
  "URL bloc": {
    "prefix": "url",
    "body": ["[${1:text}](${2:})", ""],
    "description": "Bloc URL"
  },

  "Hugo image shortcode": {
    "prefix": "blogimg",
    "body": [
      "{{< image src=\"${1:filename}.webp\" style=\"border-radius: 8px;\" >}}",
      ""
    ],
    "description": "Shortcode Hugo pour image"
  },
  "Hugo code shortcode": {
    "prefix": "blogcode",
    "body": [
      "{{< code language=\"${1:lang}\" title=\"${2:name}\" id=\"${3:1}\" expand=\"Afficher\" collapse=\"Cacher\" isCollapsed=\"true\" >}}",
      "${4:...}",
      "{{< /code >}}",
      ""
    ],
    "description": "Shortcode Hugo pour bloc de code"
  }
}
